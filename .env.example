# Okta (client-side; safe to expose with VITE_ prefix)
VITE_OKTA_ISSUER=https://your-tenant.okta.com
VITE_OKTA_CLIENT_ID=your_okta_client_id

# Local dev only. Requires `import.meta.env.DEV === true` AND this flag set to `true`
# before Okta is bypassed. A production build always ignores this.
VITE_DEV_AUTH_BYPASS=false

# Monday proxy (server-side only; do NOT prefix with VITE_)
MONDAY_API_TOKEN=your_monday_api_token
MONDAY_BOARD_ID=1000000001
MONDAY_BOARD_IDS=1000000001,1000000002,1000000003

# Board -> department mapping (JSON, server-side override)
MONDAY_BOARD_DEPARTMENT_MAP={"1000000001":"IT","1000000002":"Accounting","1000000003":"Marketing"}

# Optional column id overrides if your boards use distinct generated ids.
# Otherwise the proxy falls back to title matching.
MONDAY_AMOUNT_COLUMN_ID=
MONDAY_LENGTH_COLUMN_ID=
MONDAY_RENEWAL_METHOD_COLUMN_ID=
MONDAY_RENEWAL_DATE_LEGACY_COLUMN_ID=
MONDAY_NEXT_RENEWAL_COLUMN_ID=
MONDAY_RENEWAL_TYPE_COLUMN_ID=
MONDAY_SEATS_COLUMN_ID=
MONDAY_USE_CASE_COLUMN_ID=
MONDAY_CO_OWNERS_COLUMN_ID=

# How long the proxy caches the normalized Monday license list (ms). Default 35000.
MONDAY_CACHE_TTL_MS=

MONDAY_PROXY_PORT=8787

# Vite dev server proxies /api/* here
MONDAY_PROXY_TARGET=http://localhost:8787

# Build-time grants for the demo. Drop a JSON array of {email, role, departments}.
# When unset, a small set of placeholder example.com grants is used so the demo runs.
VITE_USER_GRANTS_JSON=

# --- Email (Azure Communication Services) ---
# Required for the renewal-reminder + test send paths.
ACS_CONNECTION_STRING=
ACS_SENDER_ADDRESS=no-reply@applications.atlantafinehomes.com

# Bearer-token-gated /api/email/test (legacy curl-friendly path).
# Settings UI uses the Okta-gated /api/email/send-test instead.
TEST_EMAIL_SECRET=

# --- Email log persistence ---
# Defaults to /home/data in production (App Service persistent storage) and
# ./data in dev. Override only if you need a custom location.
EMAIL_LOG_DIR=

# --- Settings page admin gate ---
# Server checks the Okta access token against this email for admin endpoints.
# Default is daniel@atlantafinehomes.com.
SUPER_ADMIN_EMAIL=
# Frontend override (kept in sync; defaults to the same address).
VITE_SUPER_ADMIN_EMAIL=

# --- Okta server-side token verification (used by admin endpoints) ---
# If unset, falls back to VITE_OKTA_ISSUER.
OKTA_ISSUER=

# --- ACS sender-domain status (Azure ARM) ---
# Used by /api/email/domain-status. The service principal needs at least
# Reader on the ACS Email Communication Service resource.
ACS_SUBSCRIPTION_ID=
ACS_RESOURCE_GROUP=ApplicationTracker
ACS_EMAIL_SERVICE_NAME=
ACS_DOMAIN_NAME=applications.atlantafinehomes.com
# Optional dedicated SP for ARM; otherwise reuses AZURE_CLIENT_ID/AZURE_CLIENT_SECRET.
ACS_ARM_CLIENT_ID=
ACS_ARM_CLIENT_SECRET=

# --- Azure AD / Graph (used by /api/profile/lookup + /api/profile/photo) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Restrict /api/profile/* lookups to a single tenant domain (e.g. atlantafinehomes.com)
AZURE_PHOTO_ALLOWED_DOMAIN=

# --- Renewal reminders ---
# When unset, scheduler boots on startup. Set to "false" to disable.
REMINDERS_ENABLED=
# UTC hour (0-23) the daily reminder pass runs. Default 13 (~9am ET DST).
REMINDER_RUN_HOUR_UTC=
# Comma-separated days-out triggers. Default 90,60,30,14,7,1,-1,-30,-60,-90
# Negative numbers are post-renewal escalations (overdue chasers).
REMINDER_TRIGGER_DAYS=
# Address that receives reminders when a license has no resolvable co-owner.
REMINDER_FALLBACK_RECIPIENT=

# --- Proxy hardening (all optional) ---
# Origin allow-list for CORS, comma-separated. Defaults to
# https://applications.atlantafinehomes.com plus http://localhost:3000 for dev.
CORS_ORIGIN=
# Okta email-domain allow-list for /api/licenses + write paths. Default
# atlantafinehomes.com. Comma-separated to allow partner domains.
ALLOWED_OKTA_DOMAINS=
# Hard cap on POST body bytes. Default 262144 (256 KB).
READ_JSON_MAX_BYTES=

# --- Observability ---
# When set, server lazy-loads the `applicationinsights` SDK and pipes
# structured logger events in. Otherwise structured JSON is emitted to stdout.
APPLICATIONINSIGHTS_CONNECTION_STRING=
